{
    "compilerOptions": {
        "lib": ["ESNext", "DOM"],
        "target": "ESNext",
        "module": "ESNext",
        "moduleDetection": "force",
        "jsx": "react-jsx",
        "allowJs": true,

        "moduleResolution": "bundler",
        "verbatimModuleSyntax": true,
        "resolveJsonModule": true,

        "noEmit": true,

        "strict": true,
        "skipLibCheck": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitOverride": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noPropertyAccessFromIndexSignature": false,
        "types": ["@webgpu/types"],
        "paths": {
            "@dylanebert/shallot/src/*": ["./packages/shallot/src/*"]
        }
    },
    "include": ["packages", "examples", "scripts", "harness"],
    "exclude": [
        "**/dist",
        "**/build",
        "scripts/capture/fixture-svelte",
        "scripts/capture/fixture-react"
    ]
}
