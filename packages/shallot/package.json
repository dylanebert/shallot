{
    "name": "@dylanebert/shallot",
    "version": "0.4.0",
    "description": "WebGPU game engine. Procedural-first, ECS, declarative scenes. In development.",
    "license": "MIT",
    "author": "Dylan Ebert <dylan.ebert@gmail.com>",
    "repository": {
        "type": "git",
        "url": "https://github.com/dylanebert/shallot.git"
    },
    "homepage": "https://github.com/dylanebert/shallot",
    "bugs": "https://github.com/dylanebert/shallot/issues",
    "keywords": ["webgpu", "game-engine", "ecs", "3d", "graphics", "physics", "rendering"],
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./extras": "./src/extras/index.ts",
        "./editor": "./src/editor/index.ts",
        "./ecs/core": "./src/engine/ecs/core.ts",
        "./compute/core": "./src/standard/compute/core.ts",
        "./render/core": "./src/standard/render/core.ts",
        "./physics/core": "./src/standard/physics/gpu.ts",
        "./audio/core": "./src/standard/audio/engine.ts",
        "./transforms/core": "./src/standard/transforms/core.ts",
        "./raytracing/core": "./src/extras/raytracing/core.ts",
        "./runtime": "./src/engine/runtime/index.ts",
        "./src/*": "./src/*"
    },
    "bin": {
        "shallot": "./bin/cli.ts"
    },
    "files": [
        "src",
        "editor",
        "bin",
        "rust/transforms/pkg",
        "rust/audio/pkg",
        "AGENTS.md"
    ],
    "scripts": {
        "build": "bun run ./scripts/build.ts",
        "test": "bun test"
    },
    "dependencies": {
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "lucide-static": "^0.564.0",
        "mediabunny": "^1.34.4",
        "paneforge": "^1.0.2",
        "svelte": "^5.19.0",
        "vite": "^8.0.0"
    },
    "devDependencies": {
        "svelte-check": "^4.4.0",
        "@napi-rs/canvas": "^0.1.88",
        "@types/bun": "latest",
        "@types/three": "^0.182.0",
        "bun-webgpu": "^0.1.4",
        "fast-check": "^4.6.0",
        "three": "^0.182.0",
        "troika-three-text": "^0.52.4",
        "wgpu-matrix": "^3.4.0"
    },
    "trustedDependencies": [
        "webgpu"
    ]
}
