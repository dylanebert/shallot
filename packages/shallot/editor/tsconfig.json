    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "verbatimModuleSyntax": true,
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "types": ["@webgpu/types"]
    },
    "include": ["src"],
    "exclude": ["**/*.test.ts"]
}
