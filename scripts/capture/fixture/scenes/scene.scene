<scene>
    <a ambient-light="intensity: 0.6" />
    <a
        directional-light="direction: -0.4 -1 -0.55; color: 0xfff4e0; intensity: 1.2"
        shadow="distance: 12"
    />

    <a camera sear orbit="distance: 5; yaw: 0.5; pitch: 0.35" transform />

    <!-- named so the outliner/inspector flows have stable targets and titles read as id, not "entity" -->
    <a id="ground" part transform="pos: 0 -1.2 0; scale: 8 0.1 8" color="rgba: 0.35 0.37 0.4" />
    <a id="box" part transform="scale: 1.8 1.8 1.8" color="rgba: 0.85 0.55 0.35" />
</scene>
