<scene>
    <a ambient-light="intensity: 0.6" />
    <a directional-light="direction: -0.4 -1 -0.55; color: 0xfff4e0; intensity: 1.2" />

    <a camera sear orbit="distance: 6; yaw: 0.8; pitch: 0.4" transform />

    <!-- one part (vs demo's two) so the reload-conformance flow can tell the scenes apart by count -->
    <a id="pillar" part transform="scale: 1 3 1" color="rgba: 0.4 0.6 0.8" />
</scene>
