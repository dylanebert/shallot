<scene>
    <!-- the asset-swap flow's fixture: the Box plugin (src/box.ts) imports box.gltf and placeScene spawns it
         with the model's baseColorFactor as its Color, so the flow edits the model's color on disk and asserts
         the live swap (no page reload) re-decodes off-thread and re-renders. Only the box carries a Color, so
         it's the sole /__api/entities?component=Color hit. -->
    <a ambient-light="intensity: 0.6" />
    <a directional-light="direction: -0.4 -1 -0.55; color: 0xfff4e0; intensity: 1.2" />

    <a camera sear orbit="distance: 5; yaw: 0.5; pitch: 0.35" transform />
</scene>
