<scene>
    <a ambient-light />
    <a directional-light />
    <a camera sear orbit="distance: 13; pitch: 0.5236" transform />

    <!-- the reference line the springy curves overshoot: a retained Line at the top of the travel -->
    <a line="offset: 8 0 0; thickness: 1.5; color: 0x4a4640" transform="pos: -4 1.5 0" />

    <!-- one looping timeline; every tween reads its playhead and self-fires at its `at` offset -->
    <a id="seq" sequence="loop: 1" />

    <!-- five cubes, one easing curve each. Each rises over the first phase then falls over the second
         (fill: none, so the rise hands off to the fall cleanly), and the sequence loops the pair. -->
    <a id="c0" part transform="pos: -3.2 -1.5 0" color="rgba: 0.35 0.55 0.95" />
    <a
        tween="field: transform.pos.y; from: -1.5; to: 1.5; duration: 1.4; fill: none; target: @c0; sequence: @seq"
    />
    <a
        tween="field: transform.pos.y; from: 1.5; to: -1.5; at: 1.4; duration: 1.4; fill: none; target: @c0; sequence: @seq"
    />

    <a id="c1" part transform="pos: -1.6 -1.5 0" color="rgba: 0.4875 0.55 0.825" />
    <a
        tween="field: transform.pos.y; from: -1.5; to: 1.5; duration: 1.4; easing: ease-out-cubic; fill: none; target: @c1; sequence: @seq"
    />
    <a
        tween="field: transform.pos.y; from: 1.5; to: -1.5; at: 1.4; duration: 1.4; easing: ease-out-cubic; fill: none; target: @c1; sequence: @seq"
    />

    <a id="c2" part transform="pos: 0 -1.5 0" color="rgba: 0.625 0.55 0.7" />
    <a
        tween="field: transform.pos.y; from: -1.5; to: 1.5; duration: 1.4; easing: ease-out-back; fill: none; target: @c2; sequence: @seq"
    />
    <a
        tween="field: transform.pos.y; from: 1.5; to: -1.5; at: 1.4; duration: 1.4; easing: ease-out-back; fill: none; target: @c2; sequence: @seq"
    />

    <a id="c3" part transform="pos: 1.6 -1.5 0" color="rgba: 0.7625 0.55 0.575" />
    <a
        tween="field: transform.pos.y; from: -1.5; to: 1.5; duration: 1.4; easing: ease-out-elastic; fill: none; target: @c3; sequence: @seq"
    />
    <a
        tween="field: transform.pos.y; from: 1.5; to: -1.5; at: 1.4; duration: 1.4; easing: ease-out-elastic; fill: none; target: @c3; sequence: @seq"
    />

    <a id="c4" part transform="pos: 3.2 -1.5 0" color="rgba: 0.9 0.55 0.45" />
    <a
        tween="field: transform.pos.y; from: -1.5; to: 1.5; duration: 1.4; easing: ease-out-bounce; fill: none; target: @c4; sequence: @seq"
    />
    <a
        tween="field: transform.pos.y; from: 1.5; to: -1.5; at: 1.4; duration: 1.4; easing: ease-out-bounce; fill: none; target: @c4; sequence: @seq"
    />
</scene>
