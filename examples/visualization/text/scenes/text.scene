<scene>
    <a
        id="camera"
        camera="fov: 50; far: 100; clear-color: 0xffffff; mode: orthographic"
        fxaa
        orbit="distance: 12; min-distance: 5"
        transform
    />

    <a id="ambient" ambient-light="color: 0xf0f0f0; intensity: 0.65" />
    <a part="size: 0.6; shape: sphere; color: 0x4488cc" transform="pos: -3 1 -2" />

    <a
        pulse-size="min-size: 0.6; max-size: 1.0; frequency: 0.3"
        text="anchor: 0.5; font-size: 0.8; color: 0xc2410c; content: SHALLOT"
        transform="pos: 0 3 0"
    />

    <a
        text="anchor: 0.5; font-size: 0.5; color: 0x0d7377; content: WebGPU"
        transform="pos: -3 1 0"
        wave-text="amplitude: 0.4; frequency: 0.8; base-y: 1"
    />
    <a
        text="anchor: 0.5; font-size: 0.5; color: 0xb45309; content: Text"
        transform="pos: 0 1 0"
        wave-text="amplitude: 0.4; frequency: 0.8; phase: 1.0472; base-y: 1"
    />
    <a
        text="anchor: 0.5; font-size: 0.5; color: 0x047857; content: Rendering"
        transform="pos: 3 1 0"
        wave-text="amplitude: 0.4; frequency: 0.8; phase: 2.0944; base-y: 1"
    />

    <a
        color-cycle="hue-speed: 60; saturation: 0.85; lightness: 0.45"
        text="anchor: 0.5; font-size: 0.6; color: 0xff0000; content: Rainbow"
        transform="pos: 0 -1 0"
    />

    <a
        rotate-text="speed: 25; radius: 2.5; axis-y: -3; phase: 0"
        text="anchor: 0.5; font-size: 0.4; color: 0xc2410c; content: SDF"
        transform="pos: 0 -3 0"
    />
    <a
        rotate-text="speed: 25; radius: 2.5; axis-y: -3; phase: 90"
        text="anchor: 0.5; font-size: 0.4; color: 0x0d7377; content: Font"
        transform="pos: 0 -3 0"
    />
    <a
        rotate-text="speed: 25; radius: 2.5; axis-y: -3; phase: 180"
        text="anchor: 0.5; font-size: 0.4; color: 0xb45309; content: Atlas"
        transform="pos: 0 -3 0"
    />
    <a
        rotate-text="speed: 25; radius: 2.5; axis-y: -3; phase: 270"
        text="anchor: 0.5; font-size: 0.4; color: 0x047857; content: Glyph"
        transform="pos: 0 -3 0"
    />

    <a
        text="content: Inter; font: inter; font-size: 0.4; color: 0x374151; anchor-x: 0.5; anchor-y: 0.5"
        transform="pos: -4 -1.5 -1"
    />
    <a
        text="content: Regular; font: inter; font-size: 0.35; color: 0x4b5563; anchor-x: 0.5; anchor-y: 0.5"
        transform="pos: -4 -2.2 -1"
    />
    <a
        text="content: ABCDEFG; font: inter; font-size: 0.3; color: 0x6b7280; anchor-x: 0.5; anchor-y: 0.5"
        transform="pos: -4 -2.8 -1"
    />

    <a
        text="content: Press Start; font: pixel; font-size: 0.4; color: 0x7c3aed; anchor-x: 0.5; anchor-y: 0.5"
        transform="pos: 4 -1.5 -1"
    />
    <a
        text="content: 2P Pixel; font: pixel; font-size: 0.35; color: 0x8b5cf6; anchor-x: 0.5; anchor-y: 0.5"
        transform="pos: 4 -2.2 -1"
    />
    <a
        text="content: ABCDEFG; font: pixel; font-size: 0.3; color: 0xa78bfa; anchor-x: 0.5; anchor-y: 0.5"
        transform="pos: 4 -2.8 -1"
    />
</scene>
