<scene>
    <a id="orbit-target" transform="pos: 1 0 0" />
    <a
        id="camera"
        camera="fov: 45; far: 100; clear-color: 0xffffff"
        fxaa
        orbit="min-distance: 3; max-distance: 25"
        target="@orbit-target"
        transform
    />

    <a id="ambient" ambient-light="intensity: 0.55" />
    <a id="key-light" directional-light="direction: 0.5 -1 -0.3; intensity: 0.7" />

    <a
        id="parent"
        orbit-parent="speed: 30"
        part="size: 1.2; shape: sphere; color: 0xe07a5f"
        transform="pos: 0"
    >
        <a
            id="child"
            part="size: 0.6; shape: box; color: 0x3d9ca8"
            self-spin="speed: 120"
            transform="pos: 3 0 0"
        >
            <a
                id="grandchild"
                part="size: 0.25; shape: sphere; color: 0xd4a853"
                self-spin="speed: -200"
                transform="pos: 1.2 0 0"
            />
        </a>
    </a>

    <a
        id="ground-marker"
        part="size: 6 0.05 6; shape: box; color: 0xe8e8e8"
        transform="pos: 0 -2 0"
    />
</scene>
