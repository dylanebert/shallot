<scene>
    <a
        id="camera"
        camera="fov: 50; far: 100; clear-color: 0xffffff"
        fxaa
        orbit="min-distance: 4; max-distance: 25"
        transform
    />

    <a id="ambient" ambient-light="color: 0xf0f0f0; intensity: 0.6" />

    <a
        id="wave-h"
        arrow="end: 1"
        line="offset-x: 2.5; color: 0xe07a5f; thickness: 3"
        transform="pos: -3 2.5 0"
        wave-offset="base-offset-x: 2.5; amplitude-y: 1.2; frequency: 0.6; phase: 0"
    />
    <a
        id="wave-v"
        arrow="end: 1"
        line="offset-y: 2; color: 0x3d9ca8; thickness: 3"
        transform="pos: 0 2.5 0"
        wave-offset="base-offset-y: 2; amplitude-x: 1; frequency: 0.8; phase: 1.57"
    />
    <a
        id="wave-z"
        arrow="end: 1"
        line="offset-z: 2; color: 0xd4a853; thickness: 3"
        transform="pos: 3 2.5 0"
        wave-offset="base-offset-z: 2; amplitude-x: 0.8; amplitude-y: 0.5; frequency: 0.5; phase: 3.14"
    />

    <a
        id="pulse-1"
        arrow="start: 1; end: 1"
        line="offset-x: 2; color: 0xc96b55; thickness: 2"
        pulse-thickness="min-thickness: 2; max-thickness: 6; frequency: 0.7; phase: 0"
        transform="pos: -3.5 0 0"
    />
    <a
        id="pulse-2"
        arrow="end: 1"
        line="offset-x: 2; color: 0xe07a5f; thickness: 2"
        pulse-thickness="min-thickness: 2; max-thickness: 5; frequency: 0.7; phase: 1.05"
        transform="pos: -0.5 0 0"
    />
    <a
        id="pulse-3"
        arrow="start: 1"
        line="offset-x: 2; color: 0xf08a6f; thickness: 2"
        pulse-thickness="min-thickness: 2; max-thickness: 4; frequency: 0.7; phase: 2.1"
        transform="pos: 2.5 0 0"
    />

    <a
        id="arrow-pulse-1"
        arrow="end: 1"
        line="offset-x: 2.5; color: 0x3d9ca8; thickness: 2.5"
        pulse-arrow="min-size: 0.6; max-size: 1.8; frequency: 0.6; phase: 0"
        transform="pos: -3 -2.5 0"
    />
    <a
        id="arrow-pulse-2"
        arrow="start: 1; end: 1"
        line="offset-x: 2.5; color: 0x4fb3bf; thickness: 2.5"
        pulse-arrow="min-size: 0.5; max-size: 1.5; frequency: 0.6; phase: 1.57"
        transform="pos: -3 -3.5 0"
    />

    <a
        id="rotate-center"
        part="size: 0.15; shape: sphere; color: 0x888888"
        spin-y="speed: 60"
        transform="pos: 0 -3 0"
    >
        <a
            id="rotate-line-1"
            arrow="end: 1"
            line="offset-y: 2; color: 0xd4a853; thickness: 3"
            transform
        />
        <a
            id="rotate-line-2"
            arrow="end: 1"
            line="offset: 1.5; color: 0xc49543; thickness: 2.5"
            transform
        />
    </a>

    <a
        id="fade-1"
        arrow="end: 1"
        fade-opacity="min-opacity: 0.2; max-opacity: 1; frequency: 0.4; phase: 0"
        line="offset-y: -2; color: 0xe07a5f; thickness: 4; opacity: 1"
        transform="pos: 4.5 -2.5 0"
    />
    <a
        id="fade-2"
        arrow="end: 1"
        fade-opacity="min-opacity: 0.2; max-opacity: 1; frequency: 0.4; phase: 2.09"
        line="offset-y: -2; color: 0x3d9ca8; thickness: 4; opacity: 1"
        transform="pos: 5.5 -2.5 0"
    />
    <a
        id="fade-3"
        arrow="end: 1"
        fade-opacity="min-opacity: 0.2; max-opacity: 1; frequency: 0.4; phase: 4.18"
        line="offset-y: -2; color: 0xd4a853; thickness: 4; opacity: 1"
        transform="pos: 6.5 -2.5 0"
    />

    <a id="const-center" part="size: 0.2; shape: sphere; color: 0x666666" transform="pos: 0 0 -3" />
    <a
        id="const-1"
        arrow="end: 1"
        line="offset: 1.5 1 -1; color: 0x3d9ca8; thickness: 1.5"
        transform="pos: 0 0 -3"
        wave-offset="base-offset-x: 1.5; base-offset-y: 1; base-offset-z: -1; amplitude-y: 0.3; frequency: 1.2; phase: 0"
    />
    <a
        id="const-2"
        arrow="end: 1"
        line="offset: -1.2 0.8 -0.5; color: 0xe07a5f; thickness: 1.5"
        transform="pos: 0 0 -3"
        wave-offset="base-offset-x: -1.2; base-offset-y: 0.8; base-offset-z: -0.5; amplitude-x: 0.25; frequency: 1.2; phase: 2.09"
    />
    <a
        id="const-3"
        arrow="end: 1"
        line="offset: 0.3 -1.3 0.8; color: 0xd4a853; thickness: 1.5"
        transform="pos: 0 0 -3"
        wave-offset="base-offset-x: 0.3; base-offset-y: -1.3; base-offset-z: 0.8; amplitude-z: 0.4; frequency: 1.2; phase: 4.18"
    />
    <a
        id="const-4"
        line="offset: -0.8 -0.5 1.5; color: 0x4fb3bf; thickness: 1.5"
        transform="pos: 0 0 -3"
        wave-offset="base-offset-x: -0.8; base-offset-y: -0.5; base-offset-z: 1.5; amplitude-x: 0.2; amplitude-y: 0.2; frequency: 0.9; phase: 1"
    />
</scene>
