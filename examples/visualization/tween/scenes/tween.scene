<scene>
    <a
        id="camera"
        camera="fov: 50; far: 100; clear-color: 0xf5f3f0; mode: orthographic"
        fxaa
        orbit="distance: 12; min-distance: 5; max-distance: 25"
        transform
    />

    <a id="ambient" ambient-light="color: 0xf0f0f0; intensity: 0.8" />
    <a id="light" directional-light="direction: 0.3 -1 -0.4; intensity: 0.7" />

    <!-- Bounce: rise with bounce easing, fall with quad -->
    <a id="ball-bounce" part="size: 0.8; shape: sphere; color: 0xe07a5f" transform="pos: -3 -1 0" />

    <a auto-play="loop: 1" sequence>
        <a target="@ball-bounce" tween="to: 2; easing: 29; duration: 1.5; field: transform.pos-y" />
        <a pause="duration: 1.8" />
        <a target="@ball-bounce" tween="to: -1; easing: 1; duration: 0.8; field: transform.pos-y" />
    </a>

    <!-- Back: overshoot up with back easing, settle down -->
    <a id="ball-back" part="size: 0.8; shape: sphere; color: 0x3d9ca8" transform="pos: 0 -1 0" />

    <a auto-play="loop: 1" sequence>
        <a target="@ball-back" tween="to: 2; easing: 24; duration: 1.2; field: transform.pos-y" />
        <a pause="duration: 1.5" />
        <a target="@ball-back" tween="to: -1; easing: 24; duration: 1.2; field: transform.pos-y" />
    </a>

    <!-- Elastic: rise with elastic overshoot, settle with quad -->
    <a id="ball-elastic" part="size: 0.8; shape: sphere; color: 0xd4a853" transform="pos: 3 -1 0" />

    <a auto-play="loop: 1" sequence>
        <a
            target="@ball-elastic"
            tween="to: 2; easing: 26; duration: 1.8; field: transform.pos-y"
        />
        <a pause="duration: 2.1" />
        <a
            target="@ball-elastic"
            tween="to: -1; easing: 3; duration: 0.6; field: transform.pos-y"
        />
    </a>
</scene>
