<scene>
    <a ambient-light="color: 0xd0dcec" />
    <a directional-light="direction: -0.4 -1 -0.55; color: 0xfff4e0; intensity: 1.1" />

    <a
        id="camera"
        camera
        sear
        transform
        orbit="distance: 9; yaw: 0.5; pitch: 0.32; target: @center"
    />

    <a id="ground" part transform="pos: 0 -1 0; scale: 8 0.15 8" color="rgba: 0.28 0.3 0.34" />

    <a part transform="pos: -2.6 0 0" spin="speed: 0.5" color="rgba: 0.82 0.55 0.4" />
    <a id="center" part transform spin="speed: 1" color="rgba: 0.5 0.7 0.55" />
    <a part transform="pos: 2.6 0 0" spin="speed: 1.5" color="rgba: 0.45 0.55 0.7" />
</scene>
