<scene>
    <a ambient-light="color: 0xd0dcec" />
    <a directional-light="direction: -0.4 -1 -0.55; color: 0xfff4e0; intensity: 1.1" />

    <a
        id="camera"
        camera
        sear
        transform
        orbit="distance: 5.5; yaw: 0; pitch: 0.12; target: @sign"
    />

    <a id="ground" part transform="scale: 6 0.2 6" color="rgba: 0.5 0.55 0.52" />

    <a id="sign" part transform="pos: 0 1.2 0; scale: 3 1.6 0.2" color="rgba: 0.3 0.32 0.38" />

    <a
        text="anchor: 0.5; content: SHALLOT; font-size: 0.5; color: 0xffcc44"
        transform="pos: 0 1.55 0.11"
    />
    <a counter text="anchor: 0.5; font-size: 0.32; color: 0x9fe0ff" transform="pos: 0 0.9 0.11" />
</scene>
