<scene>
    <a ambient-light="color: 0xd0dcec" />
    <a directional-light="direction: -0.4 -1 -0.55; color: 0xfff4e0; intensity: 1.1" />

    <a id="camera" camera sear transform orbit="distance: 6; yaw: 0.6; pitch: 0.28; target: @hub" />

    <a id="ground" part transform="pos: 0 -1 0; scale: 8 0.15 8" color="rgba: 0.28 0.3 0.34" />

    <a id="hub" part transform="scale: 0.5 0.5 0.5" color="rgba: 0.55 0.58 0.66" />

    <a line="offset: 2 0 0; thickness: 4; color: 0xff5566" arrow transform />
    <a line="offset: 0 2 0; thickness: 4; color: 0x66dd77" arrow transform />
    <a line="offset: 0 0 2; thickness: 4; color: 0x5599ff" arrow transform />
</scene>
