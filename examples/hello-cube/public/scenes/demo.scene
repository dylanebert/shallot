<scene>
    <!-- Camera -->
    <a id="camera" camera fxaa orbit tonemap transform />

    <!-- Lighting -->
    <a ambient-light />
    <a directional-light />

    <!-- Rotating cube -->
    <a
        id="cube"
        part="size: 1; shape: box; color: 0xd49560"
        rotate-cube="speed-x: 60; speed-y: 30"
        transform="pos: 0"
    />
</scene>
