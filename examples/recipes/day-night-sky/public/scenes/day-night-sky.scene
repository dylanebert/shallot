<scene>
    <a ambient-light="color: 0xd0dcec" />
    <a directional-light="direction: -0.4 -0.8 -0.45; color: 0xfff4e0; intensity: 1.1" />

    <a
        sky="zenith: 0x89b6e9; horizon: 0xc4cdda; sun-glow: 0.5; cloud-coverage: 0.5; haze-density: 0.005"
    />

    <a
        id="camera"
        camera
        sear
        backdrop="name: sky"
        orbit="distance: 10; yaw: 0.4; pitch: 0.15"
        transform
    />

    <a part transform color="rgba: 0.85 0.55 0.35" />
</scene>
