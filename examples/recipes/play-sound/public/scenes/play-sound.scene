<scene>
    <a ambient-light="color: 0xd0dcec" />
    <a directional-light="direction: -0.4 -1 -0.55; color: 0xfff4e0; intensity: 1.1" />

    <a id="camera" camera sear orbit="distance: 9; pitch: 0.4" transform listener />

    <!-- names the interaction on open; the tone plays muted until a gesture unlocks the AudioContext -->
    <a
        text="anchor: 0.5; content: click to hear the tone; font-size: 0.4; color: 0xffcc44"
        transform="pos: 0 2.4 0"
    />

    <a part transform color="rgba: 0.45 0.5 0.55" />
    <a
        part
        sound="instrument: tone; loop: 1; volume: 0.7"
        transform="pos: 4 0 0"
        color="rgba: 0.95 0.6 0.2"
    />
</scene>
