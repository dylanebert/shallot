<scene>
    <a ambient-light="color: 0xd0dcec" />
    <a directional-light="direction: -0.4 -1 -0.55; color: 0xfff4e0; intensity: 1.1" />

    <a
        id="camera"
        camera
        sear
        transform
        orbit="distance: 8; yaw: 0.6; pitch: 0.25; target: @stack"
    />

    <a id="ground" part transform="pos: 0 -1 0; scale: 8 0.15 8" color="rgba: 0.28 0.3 0.34" />

    <a id="stack" part transform color="rgba: 0.85 0.55 0.35" />
    <a part transform="pos: -1.6 0 0.6" color="rgba: 0.5 0.6 0.75" />
    <a part transform="pos: 1.6 0 -0.4" color="rgba: 0.55 0.7 0.5" />
</scene>
