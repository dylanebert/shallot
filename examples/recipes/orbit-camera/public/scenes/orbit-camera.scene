<scene>
    <a ambient-light="color: 0xd0dcec" />
    <a directional-light="direction: -0.4 -1 -0.55; color: 0xfff4e0; intensity: 1.1" />

    <a id="camera" camera sear transform orbit="distance: 8; yaw: 0.6; pitch: 0.25; target: @box" />

    <!-- names the interaction on open; the recipe is otherwise silent until a drag/scroll -->
    <a
        text="anchor: 0.5; content: drag: orbit   scroll: zoom   right-drag: fly; font-size: 0.4; color: 0xffcc44"
        transform="pos: 0 2.4 0"
    />

    <a id="box" part transform color="rgba: 0.85 0.55 0.35" />
</scene>
