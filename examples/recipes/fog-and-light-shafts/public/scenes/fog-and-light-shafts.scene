<scene>
    <a ambient-light="color: 0xc4d0e0; intensity: 0.4" />
    <!-- `volumetric` opts the sun into god rays and `shadow` casts the sun shadow map the fog march reads:
         occluders darken the in-scatter behind them, so the shafts are the lit gaps between pillar shadows -->
    <a
        directional-light="direction: 0.58 -0.36 0.64; color: 0xfff4e0"
        volumetric
        shadow="distance: 70"
    />

    <!-- scattering/anisotropy/scatter-intensity set the shaft brightness; positive anisotropy pushes a forward glow toward the sun -->
    <a
        fog="density: 0.05; color: 0xbcc7d6; height-base: 0; height-falloff: 0.1; absorption: 0.1; scattering: 8; anisotropy: 0.66; scatter-intensity: 2.3"
    />

    <a
        id="camera"
        camera
        sear
        depth
        orbit="distance: 14; yaw: 0.7; pitch: 0.12; pan: 0 1.5 -8"
        transform
    />

    <a id="ground" part transform="pos: 0 -0.5 -12; scale: 40 0.2 40" color="rgba: 0.42 0.45 0.5" />

    <!-- a row of pillars receding into the distance: near ones read clear, far ones fade into the haze -->
    <a part transform="pos: -2 1 0; scale: 0.8 3 0.8" color="rgba: 0.82 0.5 0.34" />
    <a part transform="pos: 2 1 -4; scale: 0.8 3 0.8" color="rgba: 0.5 0.62 0.4" />
    <a part transform="pos: -2 1 -8; scale: 0.8 3 0.8" color="rgba: 0.82 0.5 0.34" />
    <a part transform="pos: 2 1 -12; scale: 0.8 3 0.8" color="rgba: 0.5 0.62 0.4" />
    <a part transform="pos: -2 1 -16; scale: 0.8 3 0.8" color="rgba: 0.82 0.5 0.34" />
    <a part transform="pos: 2 1 -20; scale: 0.8 3 0.8" color="rgba: 0.5 0.62 0.4" />
    <a part transform="pos: -2 1 -24; scale: 0.8 3 0.8" color="rgba: 0.82 0.5 0.34" />
</scene>
