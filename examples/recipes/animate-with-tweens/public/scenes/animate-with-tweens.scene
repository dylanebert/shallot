<scene>
    <a ambient-light="color: 0xd0dcec" />
    <a directional-light="direction: -0.4 -1 -0.55; color: 0xfff4e0; intensity: 1.1" />

    <a id="camera" camera sear transform orbit="distance: 7; yaw: 0.5; pitch: 0.22" />

    <a id="ground" part transform="pos: 0 -0.5 0; scale: 8 0.15 8" color="rgba: 0.28 0.3 0.34" />

    <a id="ball" part transform="pos: -1.3 0.6 0" color="rgba: 0.4 0.6 0.95" />
    <a id="lift" sequence="loop: 1" />
    <a
        tween="field: transform.pos.y; from: 0.6; to: 2.4; duration: 0.7; easing: ease-out-quad; fill: none; target: @ball; sequence: @lift"
    />
    <a
        tween="field: transform.pos.y; from: 2.4; to: 0.6; at: 0.7; duration: 0.7; easing: ease-in-quad; fill: none; target: @ball; sequence: @lift"
    />

    <a id="coin" bounce part transform="pos: 1.3 0.6 0" color="rgba: 0.95 0.75 0.35" />
</scene>
