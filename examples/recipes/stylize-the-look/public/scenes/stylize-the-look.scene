<scene>
    <a ambient-light="color: 0xd0dcec" />
    <a directional-light="direction: -0.4 -1 -0.55; color: 0xfff4e0; intensity: 1.1" />

    <a
        id="camera"
        camera
        sear
        transform
        orbit="distance: 8; yaw: 0.5; pitch: 0.28; target: @hero"
    />

    <a id="ground" part transform="pos: 0 -1 0; scale: 8 0.15 8" color="rgba: 0.28 0.3 0.34" />

    <a
        id="hero"
        part
        transform
        color="rgba: 0.82 0.55 0.4"
        outline="color: 1 0.85 0.2 1; width: 6"
    />

    <a pick part transform="pos: -2.6 0 0.4; scale: 0.7 0.7 0.7" color="rgba: 0.5 0.55 0.62" />
    <a pick part transform="pos: 2.6 0 0.4; scale: 0.7 0.7 0.7" color="rgba: 0.5 0.55 0.62" />
</scene>
