<scene>
    <!-- Camera looking into the box -->
    <a
        id="camera"
        bloom="intensity: 0.15; threshold: 0"
        camera
        orbit="pitch: 0; distance: 7; min-pitch: 0"
        raytracing
        reflections
        shadows
        transform
        viewport="height: 480"
        vignette
    />

    <a id="environment" clouds day-night="hour: 12" haze moon sky="band: 1" skylab sun />
    <a id="ambient-light" ambient-light />
    <a id="main-light" directional-light />

    <!-- Floor (white) -->
    <a id="floor" part="size: 4 0.1 4; shape: box; color: 0xf9f4ef" transform="pos: 0 -2 0" />

    <!-- Ceiling (white) -->
    <a id="ceiling" part="size: 4 0.1 4; shape: box; color: 0xf9f4ef" transform="pos: 0 2 0" />

    <!-- Back wall (white) - inset to be flush with floor/ceiling -->
    <a
        id="back-wall"
        part="size: 4 3.9 0.1; shape: box; color: 0xf9f4ef"
        transform="pos: 0 0 -1.95"
    />

    <!-- Left wall (Cornell red) - inset to be flush with floor/ceiling/back -->
    <a
        id="left-wall"
        part="size: 0.1 3.9 3.9; shape: box; color: 0xa52422"
        transform="pos: -1.95 0 0.05"
    />

    <!-- Right wall (green) - inset to be flush with floor/ceiling/back -->
    <a
        id="right-wall"
        part="size: 0.1 3.9 3.9; shape: box; color: 0x2d6b2d"
        transform="pos: 1.95 0 0.05"
    />

    <!-- Large sphere (matte) -->
    <a
        id="sphere-large"
        part="size: 1.6; shape: sphere; color: 0xf9f4ef; roughness: 0.5"
        transform="pos: -0.7 -1.15 -0.5"
    />

    <!-- Small sphere (brushed steel) -->
    <a
        id="sphere-small"
        part="size: 1; shape: sphere; color: 0x303030; roughness: 0.3; reflectivity: 0.9"
        transform="pos: 0.8 -1.45 0.5"
    />

    <!-- Cone (custom mesh) -->
    <a
        id="cone"
        mesh="geometry: cone"
        part="size: 0.8 1.2 0.8; shape: mesh; color: 0xd4a040"
        transform="pos: -0.2 -1.4 1"
    />

    <!-- Water surface -->
    <a id="water" transform water="level: -2" />

    <!-- Wave blobs (per-instance vertex displacement) -->
    <a
        id="blob1"
        mesh="geometry: blob-sphere"
        part="shape: mesh; color: 0x6890b0; size: 1.5; roughness: 0.05; reflectivity: 0.8; opacity: 0.5; surface: wave-blob"
        transform="pos: 4 -0.5 -0.3"
    />
    <a
        id="blob2"
        mesh="geometry: blob-sphere"
        part="shape: mesh; color: 0xa06078; size: 1.5; roughness: 0.05; reflectivity: 0.8; opacity: 0.5; surface: wave-blob"
        transform="pos: 4 -0.5 2"
    />
</scene>
